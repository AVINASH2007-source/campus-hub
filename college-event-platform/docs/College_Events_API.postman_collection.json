{
  "info": {
    "name": "College Events Platform API",
    "description": "Complete API test collection for the College Events Platform.\nSet BASEURL = http://localhost:8080/api/v1\nRun 'Login' first — TOKEN is auto-extracted into the collection variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASEURL", "value": "http://localhost:8080/api/v1" },
    { "key": "TOKEN",   "value": "" },
    { "key": "EVENT_ID","value": "1" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{TOKEN}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{BASEURL}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"test@college.edu\",\n  \"password\": \"Password123\",\n  \"confirmPassword\": \"Password123\",\n  \"department\": \"Computer Science\",\n  \"rollNumber\": \"CS2024999\"\n}"
            }
          }
        },
        {
          "name": "Login (auto-save token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('TOKEN', json.accessToken);",
                  "  console.log('Token saved:', json.accessToken.substring(0,30) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{BASEURL}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@college.edu\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{BASEURL}}/auth/forgot-password",
            "body": { "mode": "raw", "raw": "{ \"email\": \"test@college.edu\" }" }
          }
        }
      ]
    },
    {
      "name": "📅 Events",
      "item": [
        {
          "name": "List Events (all)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASEURL}}/events?page=0&size=12&sort=startTime,asc",
              "host": ["{{BASEURL}}"],
              "path": ["events"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "12" },
                { "key": "sort", "value": "startTime,asc" }
              ]
            }
          }
        },
        {
          "name": "List Events (by category)",
          "request": {
            "method": "GET",
            "url": "{{BASEURL}}/events?category=WORKSHOP&page=0&size=12"
          }
        },
        {
          "name": "Search Events",
          "request": {
            "method": "GET",
            "url": "{{BASEURL}}/events/search?q=hackathon"
          }
        },
        {
          "name": "Get Event by ID",
          "request": {
            "method": "GET",
            "url": "{{BASEURL}}/events/{{EVENT_ID}}"
          }
        },
        {
          "name": "Create Event (faculty/admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{TOKEN}}" }] },
            "method": "POST",
            "url": "{{BASEURL}}/events",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Python for Data Science — Bootcamp\",\n  \"description\": \"Intensive 3-day bootcamp covering pandas, numpy, matplotlib, and sklearn.\",\n  \"category\": \"WORKSHOP\",\n  \"venue\": \"CS Lab 1\",\n  \"startTime\": \"2025-09-10T09:00:00\",\n  \"endTime\": \"2025-09-12T17:00:00\",\n  \"maxParticipants\": 25,\n  \"registrationDeadline\": \"2025-09-05T23:59:00\",\n  \"fee\": 500.00,\n  \"tags\": \"python,data-science,bootcamp,ml\"\n}"
            }
          }
        },
        {
          "name": "Update Event",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{TOKEN}}" }] },
            "method": "PUT",
            "url": "{{BASEURL}}/events/{{EVENT_ID}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Python Bootcamp (Updated)\",\n  \"maxParticipants\": 30\n}"
            }
          }
        },
        {
          "name": "Delete Event",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{TOKEN}}" }] },
            "method": "DELETE",
            "url": "{{BASEURL}}/events/{{EVENT_ID}}"
          }
        }
      ]
    },
    {
      "name": "📝 Registrations",
      "item": [
        {
          "name": "Register for Event",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{TOKEN}}" }] },
            "method": "POST",
            "url": "{{BASEURL}}/registrations/events/{{EVENT_ID}}"
          }
        },
        {
          "name": "My Registrations",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{TOKEN}}" }] },
            "method": "GET",
            "url": "{{BASEURL}}/registrations/my?page=0&size=10"
          }
        },
        {
          "name": "Event Participants (organizer)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{TOKEN}}" }] },
            "method": "GET",
            "url": "{{BASEURL}}/registrations/events/{{EVENT_ID}}/participants"
          }
        },
        {
          "name": "Check-in by Token",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{TOKEN}}" }] },
            "method": "POST",
            "url": "{{BASEURL}}/registrations/check-in?token=REPLACE_WITH_TOKEN"
          }
        },
        {
          "name": "Attendance Summary",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{TOKEN}}" }] },
            "method": "GET",
            "url": "{{BASEURL}}/registrations/events/{{EVENT_ID}}/attendance-summary"
          }
        },
        {
          "name": "Cancel Registration",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{TOKEN}}" }] },
            "method": "DELETE",
            "url": "{{BASEURL}}/registrations/1"
          }
        }
      ]
    }
  ]
}
